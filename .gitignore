.DS_Store
.RData
.Rhistory
.pytest_cache/
.vscode/
__pycache__/
*.py[cod]

# Python / notebook artifacts
.ipynb_checkpoints/

# Keep the repository focused on code, configs, compact experiment inputs,
# and summary outputs. Ignore heavyweight raw data and generated run dumps.

# Data: ignore everything by default, then re-include curated experiment inputs.
data/**
!data/
